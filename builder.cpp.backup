    std::cout << "4. Deadline (jam)\n   [" << cfg.deadline_hours << "]\n   > ";
    std::getline(std::cin, input);
    if (!input.empty()) cfg.deadline_hours = std::stoi(input);

    std::cout << "5. Pesan Ransom\n   [" << cfg.ransom_message << "]\n   > ";
    std::getline(std::cin, input);
